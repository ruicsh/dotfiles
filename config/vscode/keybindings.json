[
  {
    "key": "right",
    "command": "",
    "when": "editorTextFocus && neovim.mode == 'insert'"
  },
  {
    "key": "left",
    "command": "",
    "when": "editorTextFocus && neovim.mode == 'insert'"
  },
  {
    "key": "up",
    "command": "",
    "when": "editorTextFocus && neovim.mode == 'insert'"
  },
  {
    "key": "down",
    "command": "",
    "when": "editorTextFocus && neovim.mode == 'insert'"
  },
  {
    "key": "tab",
    "command": "search.action.focusSearchList",
    "when": "searchViewletVisible && searchViewletFocus && !inputFocus"
  },
  {
    "key": "shift+tab",
    "command": "workbench.action.findInFiles",
    "when": "searchViewletVisible && searchViewletFocus"
  },
  {
    "key": "tab",
    "command": "workbench.scm.action.focusNextResourceGroup",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    "key": "shift+tab",
    "command": "workbench.scm.action.focusPreviousInput",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm'"
  },
  {
    "key": "s",
    "command": "git.stage",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm' && !inputFocus"
  },
  {
    "key": "u",
    "command": "git.unstage",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm' && !inputFocus"
  },
  {
    "key": "x",
    "command": "git.clean",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.scm' && !inputFocus"
  }
]
