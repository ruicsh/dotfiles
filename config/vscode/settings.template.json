{
  "breadcrumbs.enabled": true,
  "breadcrumbs.symbolSortOrder": "name",
  "breadcrumbs.symbolPath": "off",
  "editor.minimap.enabled": false,
  "editor.scrollBeyondLastLine": false,
  "editor.tabSize": 2,
  "explorer.openEditors.visible": 1,
  "extensions.autoUpdate": true,
  "extensions.ignoreRecommendations": true,
  "files.simpleDialog.enable": true,
  "git.path": "__GIT_EXECUTABLE_PATH__",
  "gitlens.menus": {
    "editorGroup": {
      "blame": false,
      "compare": false
    }
  },
  "gitlens.views.commits.showBranchComparison": false,
  "gitlens.views.commits.pullRequests.enabled": false,
  "gitlens.views.commits.files.compact": false,
  "gitlens.views.commits.avatars": false,
  "gitlens.views.fileHistory.avatars": false,
  "gitlens.views.showRelativeDateMarkers": false,
  "javascript.suggest.autoImports": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "scm.defaultViewMode": "tree",
  "shellcheck.disableVersionCheck": true,
  "shellcheck.exclude": ["SC1090", "SC1091"],
  "shellcheck.executablePath": "__SHELLCHECK_EXECUTABLE_PATH__",
  "shellcheck.run": "onSave",
  "stylelint.stylelintPath": "./node_modules/stylelint",
  "typescript.suggest.autoImports": false,
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "window.titleBarStyle": "custom",
  "workbench.colorCustomizations": {
    "editor.selectionBackground": "#81a1c1",
    "editor.selectionForeground": "#2e3440"
  },
  "workbench.editor.decorations.badges": false,
  "workbench.editor.decorations.colors": false,
  "workbench.panel.defaultLocation": "right",
  "workbench.startupEditor": "newUntitledFile",
  "cSpell.userWords": [],
  "editor.inlineSuggest.enabled": true,
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[dockerfile]": {
    "editor.formatOnSave": false
  },
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.test.ts, ${capture}.test.tsx, ${capture}.d.ts",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts, ${capture}.module.scss, ${capture}.test.tsx, ${capture}.test.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, bun.lockb"
  },
  "debug.javascript.autoAttachFilter": "onlyWithFlag",
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[properties]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[terraform]": {
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "explorer.fileNesting.expand": false,
  "postcssSorting.config": {
    "properties-order": "alphabetical"
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "workbench.layoutControl.enabled": false,
  "editor.fontFamily": "jetbrains mono, monospace",
  "errorLens.fontFamily": "jetbrains mono, monospace",
  "terraform.languageServer.enable": true,
  "redhat.telemetry.enabled": false,
  "workbench.editorAssociations": {
    "*.pdf": "default"
  },
  "totalTypeScript.hideAllTips": false,
  "totalTypeScript.hideBasicTips": true,
  "totalTypeScript.hiddenTips": [
    "in-operator-narrowing",
    "passing-generics-to-types",
    "keyof",
    "non-null-expression",
    "partial-utility-type",
    "record-utility-type",
    "interface-with-generics",
    "generic-slots-in-functions",
    "omit-utility-type",
    "typeof",
    "type-alias-with-generics",
    "tuple-type",
    "interface-with-multiple-generics",
    "type-predicate",
    "as-const",
    "pick-utility-type",
    "returntype-utility-type",
    "type-alias-with-multiple-generics",
    "conditional-type",
    "infer",
    "never-keyword",
    "parameters-utility-type"
  ],
  "remote.portsAttributes": {
    "443": {
      "protocol": "https"
    },
    "8443": {
      "protocol": "https"
    }
  },
  "workbench.editor.enablePreview": false,
  "[python]": {
    "editor.formatOnType": true
  },
  "workbench.activityBar.visible": false,
  "workbench.iconTheme": "seti",
  "workbench.editor.limit.value": 5,
  "workbench.editor.limit.enabled": true,
  "editor.accessibilitySupport": "off",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "yaml": true,
    "dockerfile": true
  },
  "errorLens.excludeBySource": ["ts(2451)"],
  "workbench.colorTheme": "Visual Studio Dark",
  "remote.SSH.remotePlatform": {
    "sandbox.omm4xv.csb": "linux"
  },
  "cSpell.enableFiletypes": ["!plaintext"],
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "editor.formatOnSave": true,
  "editor.fontLigatures": true
}
