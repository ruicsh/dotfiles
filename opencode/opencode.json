{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Primary coding agent that delegates command execution to @executor",
      "model": "github-copilot/gemini-3-flash-preview",
      "permission": {
        "bash": "deny",
        "task": "allow"
      },
      "prompt": "{file:./prompts/build.md}"
    },
    "explore": {
      "description": "Fast codebase exploration",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "auto",
      "prompt": "{file:./prompts/explore.md}",
      "mode": "subagent",
    },
    "plan": {
      "description": "Structured implementation planning",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./prompts/plan.md}"
    },
    "executor": {
      "description": "Default execution subagent for bash commands, tests, builds, and validation",
      "model": "opencode-go/deepseek-v4-flash",
      "mode": "subagent",
      "prompt": "{file:./prompts/executor.md}"
    },
  },
  "default_agent": "plan",
  "command": {
    "commit": {
      "description": "Stage and commit changes with auto-generated conventional commit messages",
      "model": "opencode-go/deepseek-v4-flash",
      "template": "{file:./commands/commit.md}"
    },
    "review": {
      "description": "Automated review agent",
      "model": "opencode/big-pickle",
      "template": "{file:./commands/review.md}"
    }
  },
  "instructions": [
    "./prompts/general.md",
  ],
  "permission": {
    "lsp": "allow",
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "edit": {
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
    "bash": {
      "rm *credentials*": "deny",
      "rm *.env*": "deny",
      "rm -rf /": "deny",
      "git push --force": "deny",
      "curl * | sh": "deny",
      "wget * | sh": "deny"
    },
    "websearch": "ask",
    "webfetch": "ask"
  },
  "experimental": {
    "disable_paste_summary": true,
  },
}
